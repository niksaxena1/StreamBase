NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Spotify (server-side only; do NOT prefix with NEXT_PUBLIC_)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# RapidAPI (server-side only; used for Spotify stream count fallback on stale tracks)
RAPIDAPI_KEY=

# Supabase service role (server-side only) for admin caching writes (never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=

# SAI (SpotiBase AI)
# Optional: enable docs embeddings (vector RAG) + admin-only reindex endpoint
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
SAI_EMBED_DIMS=1536
SAI_ADMIN_TOKEN=

# Optional: enables extra fields on GET /api/health-summary when debug=1; send same value in header x-sb-health-debug-token (never use query strings for secrets).
SB_HEALTH_DEBUG_TOKEN=

# Secret for on-demand ISR revalidation (used by /api/revalidate)
REVALIDATE_SECRET=

# Cron jobs: Vercel sends this as Bearer token when invoking cron endpoints (e.g. ensure-partitions).
# Generate with: openssl rand -hex 32
CRON_SECRET=

